<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spring_boot.projectEx.model.IMemberDAO">
	<!-- public String loginCheck(HashMap<String,Object> map) : 로그인 기능 -->
	<select id="loginCheck" parameterType="hashmap" resultType="string">
		SELECT memId FROM member WHERE memId=#{id} AND memPwd=#{pwd}
	</select>
	<!-- public String idCheck(String id) -->
	<select id="idCheck" resultType="string" parameterType="string">
		SELECT memId FROM member WHERE memId=#{id}
	</select>
</mapper>